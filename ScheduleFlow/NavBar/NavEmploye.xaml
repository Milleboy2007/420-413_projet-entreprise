<UserControl x:Class="ScheduleFlow.NavBar.NavEmploye"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ScheduleFlow.NavBar"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Background="#424242">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="ScheduleFlow" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>

                <!--<Border Width="40" Height="40" CornerRadius="20" Grid.Column="1" Margin="0,0,20,0" VerticalAlignment="Center">
                    <Border.Background>
                        <ImageBrush ImageSource="pfp.png"/>
                    </Border.Background>
                </Border>-->
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Background="#1C5084" Height="35">
                <TextBlock x:Name="PageAccueil" MouseLeftButtonDown="PageAccueil_Click" Text="Accueil" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
                <TextBlock x:Name="PageCompte" MouseLeftButtonDown="PageCompte_Click" Text="Compte" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
                <TextBlock x:Name="PageDispo" MouseLeftButtonDown="PageDispo_Click" Text="Feuilles de disponibilité" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
                <TextBlock x:Name="PageQuart" MouseLeftButtonDown="PageQuart_Click" Text="Quart de Travail" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
                <TextBlock x:Name="PageConge" MouseLeftButtonDown="PageConge_Click" Text="Demande de Congé" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
                <TextBlock x:Name="PageNotif" MouseLeftButtonDown="PageNotif_Click" Text="Notifications" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
            </StackPanel>
        </Grid>

        <ContentControl x:Name="EmployeArea" Grid.Row="1"/>
    </Grid>
</UserControl>
