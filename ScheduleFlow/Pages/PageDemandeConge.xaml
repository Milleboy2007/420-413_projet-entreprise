<Page x:Class="ScheduleFlow.Pages.PageDemandeConge"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ScheduleFlow.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageDemandeConge"
      Background="#ffffff">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#093C71" Height="60">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="ScheduleFlow" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>

            <Border Width="40" 
                    Height="40" 
                    CornerRadius="20"
                    Grid.Column="1"
                    Margin="0,0,20,0"
                    VerticalAlignment="Center">
                <Border.Background>
                    <ImageBrush ImageSource="pfp.png"/>
                </Border.Background>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    Background="#093C71" 
                    Height="35">

            <TextBlock Text="Accueil" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
            <TextBlock Text="Compte" Foreground="White" FontWeight="Bold" Padding="15,8"/>
            <TextBlock Text="Feuilles de disponibilité" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
            <TextBlock Text="Quart de Travail" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
            <TextBlock Text="Demande de Congé" Foreground="White" FontWeight="SemiBold" Padding="15,8" Background="#1561AF"/>
            <TextBlock Text="Notifications" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0" Background="#1561AF">
                <TextBlock Text="Demande de Congé" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>
                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Poste occupé" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="Designer UI" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Date du début du congé" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="30 mars 2026" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Date de la fin du congé" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="1 avril 2026" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Raisons du congé" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="Deuil" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Notes Importantes" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="Disponible pour des questions" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>
                <Button Content="Soumettre la demande de congé régulier" 
                        Background="#093C71" 
                        Foreground="White" 
                        FontWeight="SemiBold"
                        Padding="10,5" 
                        Width="262" Height="37" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,10,0" Background="#1561AF">
                <TextBlock Text="Demande de Congé de Maladie" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>
                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Poste occupé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                    <TextBlock Text="Designer UI" 
                                   Foreground="White" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Date du début du congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                    <TextBlock Text="30 mars 2026" 
                                   Foreground="White" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Date de la fin du congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                    <TextBlock Text="Durée indéterminée" 
                                   Foreground="White" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Raisons du congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                    <TextBlock Text="Maladie" 
                                   Foreground="White" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Notes Importantes" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                    <TextBlock Text="Aucune notes disponible" 
                                   Foreground="White" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"/>
                </StackPanel>
                <Button Content="Soumettre la demande de congé de maladie" 
                        Background="#093C71" 
                        Foreground="White" 
                        FontWeight="SemiBold"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Padding="10,5" 
                        Width="262" Height="37" />
            </StackPanel>
        </Grid>
    </Grid>

</Window>
