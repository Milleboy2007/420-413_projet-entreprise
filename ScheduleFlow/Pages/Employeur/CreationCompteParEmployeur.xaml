<UserControl x:Class="ScheduleFlow.Pages.Employeur.CreationCompteParEmployeur" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:ScheduleFlow.Pages.Employeur" mc:Ignorable="d" d:DesignWidth="800" Height="450" Background="#F5F5F7">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Padding="30,20,30,20">
            <StackPanel>
                <TextBlock Text="Inscription du gérant" FontSize="20" FontWeight="Bold" Margin="0,0,0,0" Foreground="#333333"/>
                <TextBlock Text="Veuillez remplir toutes les informations requises pour enregistrer un nouveau gérant." FontSize="12" TextWrapping="Wrap" Foreground="#666666" Margin="0,0,0,20"/>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Padding="30">
                <StackPanel>
                    <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Informations personnelles" FontSize="14" FontWeight="Bold" Margin="0,0,0,15" Foreground="#333333"/>
                            <Label Content="Prénom *" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding Prenom, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                            <Label Content="Nom *" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                            <Label Content="Genre" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding Genre, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                            <Label Content="Date de naissance" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding DateNaissance, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,0" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Informations de compte" FontSize="14" FontWeight="Bold" Margin="0,0,0,15" Foreground="#333333"/>
                            <Label Content="Courriel *" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding Courriel, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                            <Label Content="Mot de passe *" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding MotDePasse, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                            <Label Content="Courriel Entreprise" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding CourrielEntreprise, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,0" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Informations d'adresse" FontSize="14" FontWeight="Bold" Margin="0,0,0,15" Foreground="#333333"/>
                            <Label Content="Adresse *" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding Adresse, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                            <Label Content="Pays *" FontSize="12" Foreground="#333333" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Pays, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                            <Label Content="Ville *" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding Ville, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                            <Label Content="Région, Province ou État" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding RegionProvince, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                            <Label Content="Code postal *" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding CodePostal, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,0" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Informations de contact" FontSize="14" FontWeight="Bold" Margin="0,0,0,15" Foreground="#333333"/>
                            <Label Content="Numéro de téléphone personnel" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding NumeroTelephonePersonnel, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                            <Label Content="Numéro de téléphone professionnel" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding NumeroTelephoneProfessionnel, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,0" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Contact d'urgence" FontSize="14" FontWeight="Bold" Margin="0,0,0,15" Foreground="#333333"/>
                            <Label Content="Nom de contact *" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding NomContactUrgence, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                            <Label Content="Téléphone du contact *" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding TelephoneContactUrgence, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                            <TextBlock Text="Lien de parenté *" FontSize="12" Margin="0,0,0,8" Foreground="#333333"/>
                            <TextBox Text="{Binding LienParente, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="12" Margin="0,0,0,0" Background="White" BorderThickness="1" BorderBrush="#CCCCCC" Foreground="#333333"/>
                        </StackPanel>
                    </Border>
                    <StackPanel HorizontalAlignment="Right" Margin="0,20,0,20">
                        <Button Command="{Binding AjouterGerantCommand}" Content="Envoyer" Height="45" Width="120" Padding="20,12" Background="#333333" Foreground="White" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>