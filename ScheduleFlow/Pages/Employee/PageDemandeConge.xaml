<UserControl x:Class="ScheduleFlow.Pages.Employee.PageDemandeConge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ScheduleFlow.Pages.Employee"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#ffffff">

    <Grid>
        <Grid Margin="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0" Background="#1561AF">
                <TextBlock Text="Demande de Congé" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>
                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Poste occupé" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="Designer UI" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Date du début du congé" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="30 mars 2026" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Date de la fin du congé" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="1 avril 2026" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Raisons du congé" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="Deuil" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Notes Importantes" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="Disponible pour des questions" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>
                <Button Content="Soumettre la demande de congé régulier" 
                        Background="#093C71" 
                        Foreground="White" 
                        FontWeight="SemiBold"
                        Padding="10,5" 
                        Width="262" Height="37" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,10,0" Background="#1561AF">
                <TextBlock Text="Demande de Congé de Maladie" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>
                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Poste occupé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                    <TextBlock Text="Designer UI" 
                                   Foreground="White" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Date du début du congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                    <TextBlock Text="30 mars 2026" 
                                   Foreground="White" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Date de la fin du congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                    <TextBlock Text="Durée indéterminée" 
                                   Foreground="White" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Raisons du congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                    <TextBlock Text="Maladie" 
                                   Foreground="White" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="20,0,0,10">
                    <TextBlock Text="Notes Importantes" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                    <TextBlock Text="Aucune notes disponible" 
                                   Foreground="White" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"/>
                </StackPanel>

                <Button Content="Soumettre la demande de congé de maladie" 
                        Background="#093C71" 
                        Foreground="White" 
                        FontWeight="SemiBold"
                        Padding="10,5" 
                        Width="262" Height="37" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>