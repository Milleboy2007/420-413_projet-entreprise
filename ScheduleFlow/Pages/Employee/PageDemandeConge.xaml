<UserControl x:Class="ScheduleFlow.Pages.Employee.PageDemandeConge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ScheduleFlow.Pages.Employee"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="White">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20" VerticalAlignment="Center">

            <Border CornerRadius="15" Background="#093C71" MaxWidth="800" Padding="40">
                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Demande de Congé" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,20,0,15"
                           HorizontalAlignment="Center"/>

                    <StackPanel>
                        <StackPanel Margin="20,0,20,15" >
                            <TextBlock Text="Type de congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                            <TextBox Text="{Binding TypeConge, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                    Foreground="Black" 
                                    FontSize="16" 
                                    FontWeight="SemiBold"
                                    VerticalContentAlignment="Center"
                                    Height="35"
                                    Margin=" 0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Margin="20,0,20,15">
                            <TextBlock Text="Date du début du congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                            <DatePicker SelectedDate="{Binding DateDebut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged }" 
                                    Foreground="Black" 
                                    FontSize="16" 
                                    FontWeight="SemiBold"
                                    VerticalContentAlignment="Center"
                                    Height="35"/>
                        </StackPanel>

                        <StackPanel Margin="20,0,20,15">
                            <TextBlock Text="Date de la fin du congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                            <DatePicker SelectedDate="{Binding DateFin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                    Foreground="Black" 
                                    FontSize="16" 
                                    FontWeight="SemiBold"
                                    VerticalContentAlignment="Center"
                                    Height="35"/>
                        </StackPanel>

                        <StackPanel Margin="20,0,20,15">
                            <TextBlock Text="Raison du congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                            <TextBox Text="{Binding Raison, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                   Foreground="Black"
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   VerticalContentAlignment="Center"
                                   Height="35"
                                   Margin=" 0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Margin="20,0,20,15">
                            <TextBlock Text="Statut" 
                                    Foreground="LightGray" 
                                    FontSize="12"/> 
                            <TextBlock Text="{Binding Statut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                    Foreground="Black"
                                    Background="White"
                                    FontSize="16" 
                                    FontWeight="SemiBold"
                                    Height="35"
                                    Margin=" 0,5,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Click="Button_Click" 
                            Background="#1561AF" 
                            Foreground="White" 
                            Height="50" 
                            FontSize="15"
                            FontWeight="Bold"
                            BorderThickness="0" Width="250">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        Soumettre la demande
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
