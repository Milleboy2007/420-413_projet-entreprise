<UserControl x:Class="ScheduleFlow.Pages.Employee.PageDemandeConge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ScheduleFlow.Pages.Employee"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#ffffff">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border CornerRadius="10" Background="#1561AF">
                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Demande de Congé" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,20,0,15"
                           HorizontalAlignment="Center"/>

                    <StackPanel>
                        <StackPanel Margin="20,0,20,10" >
                            <TextBlock Text="Type de congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                            <TextBox Text="{Binding TypeConge}" 
                                    Foreground="Black" 
                                    FontSize="15" 
                                    FontWeight="SemiBold"
                                    Height="25"
                                    Margin=" 0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Margin="20,0,20,10">
                            <TextBlock Text="Date du début du congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                            <DatePicker SelectedDate="{Binding DateDebutConge}" 
                                    Foreground="Black" 
                                    FontSize="15" 
                                    FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Margin="20,0,20,10">
                            <TextBlock Text="Date de la fin du congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                            <DatePicker SelectedDate="{Binding DateFinConge}" 
                                    Foreground="Black" 
                                    FontSize="15" 
                                    FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Margin="20,0,20,10">
                            <TextBlock Text="Raison du congé" 
                                   Foreground="LightGray" 
                                   FontSize="12"/>
                            <TextBox Text="{Binding RaisonConge}" 
                                   Foreground="Black"
                                   FontSize="15" 
                                   FontWeight="SemiBold"
                                   Height="25"
                                   Margin=" 0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Margin="20,0,20,10">
                            <TextBlock Text="Statut" 
                            Foreground="LightGray" 
                            FontSize="12"/>
                            <TextBlock Text="{Binding Statut}" 
                            Foreground="Black"
                            Background="White"
                            FontSize="15" 
                            FontWeight="SemiBold"
                            Height="25"
                            Margin=" 0,5,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Background="Transparent" BorderThickness="0" Margin="0,15,0,0">
                        <Border BorderThickness="0,1,0,0" 
                                CornerRadius="10"
                                Background="#093C71"
                                Width="262"
                                Height="45">
                            <TextBlock Text="Soumettre la demande" 
                                       Foreground="White" 
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center" 
                                       FontWeight="Bold"/>
                        </Border>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>