<UserControl x:Class="ScheduleFlow.Pages.Employee.Dispo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ScheduleFlow.Pages.Employee"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#F4F7F9">

        <UserControl.Resources>
        <Style x:Key="DayHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,10"/>
        </Style>

        <Style x:Key="TimeLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,-8,10,0"/>
        </Style>

        <Style x:Key="CalendarCellStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E0E6ED"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="MinHeight" Value="45"/>
        </Style>

        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#69D941"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="794.04"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="Mes disponibilités" 
                           FontSize="32" 
                           FontWeight="Light" 
                           Foreground="#2C3E50"
                           HorizontalAlignment="Left" 
                           Margin="10,25,0,726"/>

                <Border Background="White" CornerRadius="12" Padding="15" Margin="9,73,13,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.1"/>
                    </Border.Effect>

                    <Grid ShowGridLines="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Column="1" Text="Lundi" Style="{StaticResource DayHeaderStyle}"/>
                        <TextBlock Grid.Column="2" Text="Mardi" Style="{StaticResource DayHeaderStyle}"/>
                        <TextBlock Grid.Column="3" Text="Mercredi" Style="{StaticResource DayHeaderStyle}"/>
                        <TextBlock Grid.Column="4" Text="Jeudi" Style="{StaticResource DayHeaderStyle}"/>
                        <TextBlock Grid.Column="5" Text="Vendredi" Style="{StaticResource DayHeaderStyle}"/>
                        <TextBlock Grid.Column="6" Text="Samedi" Style="{StaticResource DayHeaderStyle}"/>
                        <TextBlock Grid.Column="7" Text="Dimanche" Style="{StaticResource DayHeaderStyle}"/>

                        <TextBlock Text="8:00" Style="{StaticResource TimeLabelStyle}" Margin="28,10,0,0" HorizontalAlignment="Left" Height="16" Grid.Row="1"/>
                        <TextBlock Grid.Row="2" Text="9:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="3" Text="10:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="4" Text="11:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="5" Text="12:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="6" Text="13:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="7" Text="14:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="8" Text="15:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="9" Text="16:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="10" Text="17:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="11" Text="18:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="12" Text="19:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="13" Text="20:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="14" Text="21:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>
                        <TextBlock Grid.Row="15" Text="22:00" Style="{StaticResource TimeLabelStyle}" Margin="0,10,10,0"/>

                        <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="15" Grid.ColumnSpan="7" 
                                BorderBrush="#ECF0F1" BorderThickness="1,1,0,0" Opacity="0.5">
                            <Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,432,779"/>
                <Button 
                Content="Ajouter une disponibilité"   
                Click="OpenPopup_Click"
                HorizontalAlignment="Left" 
                Height="25" 
                Margin="266,36,0,0" 
                VerticalAlignment="Top" 
                Width="175"
                Style="{StaticResource AddButtonStyle}"/>
            </Grid>
            <Grid x:Name="PopupOverlay" Visibility="Collapsed" Background="#80000000">
                <Border Background="White" 
                    CornerRadius="15" 
                    Width="400" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Padding="30">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" Opacity="0.3"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="Nouvelle Disponibilité" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <TextBlock Text="Jour de la semaine" Foreground="#7F8C8D" Margin="0,10,0,5"/>
                        <ComboBox x:Name="DayComboBox" Margin="0,0,0,15">
                            <ComboBoxItem Content="Lundi"/>
                            <ComboBoxItem Content="Mardi"/>
                            <ComboBoxItem Content="Mercredi"/>
                            <ComboBoxItem Content="Jeudi"/>
                            <ComboBoxItem Content="Vendredi"/>
                            <ComboBoxItem Content="Samedi"/>
                            <ComboBoxItem Content="Dimanche"/>
                        </ComboBox>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,5,0">
                                <TextBlock Text="Heure Début" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                                <TextBox x:Name="StartTimeBox" Text="08:00"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Heure Fin" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                                <TextBox x:Name="EndTimeBox" Text="17:00"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                            <Button Content="Annuler" 
                            Click="CancelPopup_Click"
                            Background="Transparent" 
                            Foreground="#E74C3C" 
                            BorderThickness="0" 
                            Margin="0,0,20,0"
                            Cursor="Hand"/>
                            <Button Content="Enregistrer" 
                        Click="SaveDispo_Click"
                        Style="{StaticResource AddButtonStyle}" 
                        Padding="20,10"
                        Height="Auto"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>