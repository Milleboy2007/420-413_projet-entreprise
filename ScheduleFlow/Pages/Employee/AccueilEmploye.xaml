<UserControl x:Class="ScheduleFlow.Pages.Employee.AccueilEmploye"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ScheduleFlow.Pages.Employee"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="#FFF0F0F0">
    <StackPanel>
        <StackPanel Orientation="Horizontal" Margin="10, 10, 0, 0">
            <Ellipse Width="60" Height="60" Fill="LightGray"/>
            <TextBlock Text="Bonjour Billy Umma" FontSize="24" FontWeight="Bold"
        VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border CornerRadius="15" Background="White" Padding="15" Margin="5,0,10,0">
                    <StackPanel Width="315">
                        <TextBlock Text="Publications" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border CornerRadius="15" Background="White" Padding="15" Margin="0,0,10,0" Width="222">
                    <StackPanel Width="175">
                        <TextBlock Text="Tableau de bord" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border CornerRadius="15" Background="White" Padding="15" Margin="0,0,10,0">
                    <StackPanel Width="175">
                        <TextBlock Text="Mes quarts" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
        </StackPanel>
    </StackPanel>
</UserControl>