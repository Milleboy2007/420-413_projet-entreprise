<UserControl x:Class="ScheduleFlow.Pages.Employee.AccueilEmploye"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ScheduleFlow.Pages.Employee"
      xmlns:enums="clr-namespace:Domaine.Enum;assembly=Domaine"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="#FFF0F0F0">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Ellipse Width="60" Height="60" Fill="LightGray"/>
            <TextBlock Text="Bonjour Billy Umma"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="15" Background="LightGray" Padding="10" Margin="5">
                <StackPanel>
                    <TextBlock Text="Publications" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Border CornerRadius="15" Background="White" Padding="10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="20" Height="20" Fill="LightGray" Margin="0,0,5,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Ted Thibeault" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="À: B.U. + 15 others..." FontSize="12"/>
                                        <TextBlock Text="Sujet: Quarts disponible entrepôt" FontSize="12" FontStyle="Italic"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock TextWrapping="Wrap" Margin="0,10,0,5">
                                    Bonjour tout le monde,
                                    Je viens de rendre les quarts disponibles de cette semaine. Veuillez vous diriger vers votre horaire pour les regarder.
                                    Beau travail tout le monde !
                                </TextBlock>

                                <TextBlock Text="Envoyé le: 27 février à 18h32"
                                           FontSize="10"
                                           Foreground="Gray"
                                           HorizontalAlignment="Right"/>

                                <Button Content="Afficher publications"
                                        HorizontalAlignment="Right"
                                        Margin="0,10,0,0"
                                        Padding="8,2"
                                        Background="#2F6690"
                                        Foreground="White"
                                        BorderThickness="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#2F6690"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3A7CA5"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                        
                    <TextBlock Grid.Row="2" Text="Mes demandes de congé" FontWeight="Bold" Margin="5,0,0,5" Foreground="#333"/>
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ListeDemandes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White"
                                            CornerRadius="10"
                                            Padding="12,8"
                                            Margin="0,0,0,8"
                                            BorderBrush="#DDD"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding TypeConge}" FontWeight="Bold" Foreground="#093C71"/>
                                                    <TextBlock Text=" . " Foreground="Gray"/>
                                                    <TextBlock Text="{Binding Raison}" FontSize="11" Foreground="#555" MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <TextBlock FontSize="10" Foreground="Gray">
                                            <Run Text="Du "/>
                                            <Run Text="{Binding DateDebut, StringFormat=d}"/>
                                            <Run Text="au "/>
                                            <Run Text="{Binding DateFin, StringFormat=d}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Border Grid.Column="1"
                                            CornerRadius="5"
                                            Padding="6,2"
                                            VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#EEE"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Statut}" Value="{x:Static enums:EtatStatut.Approuve}">
                                                                <Setter Property="Background" Value="#D4EDDA" />
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding Statut}" Value="{x:Static enums:EtatStatut.EnAttente}">
                                                                <Setter Property="Background" Value="#FFF3CD"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Statut}" Value="{x:Static enums:EtatStatut.Refuse}">
                                                                <Setter Property="Background" Value="#F8D7DA"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Statut}" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" CornerRadius="15" Background="White" Padding="15" Margin="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Tableau de bord" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold"/>

                        <TextBlock Text="Détails du poste" FontWeight="Bold" Margin="0,10,0,0"/>
                        <TextBlock Text="Poste occupé: Commis d'entrepot"/>
                        <TextBlock Text="Depuis: Janvier 2026"/>
                        <TextBlock Text="Nombre d'heures travaillées: 79h"/>
                        <TextBlock Text="Argent reçu: 1296 $"/>
                        <TextBlock Text="Argent dû: 126 $"/>

                        <TextBlock Text="Détails de quarts" FontWeight="Bold" Margin="0,10,0,0"/>
                        <TextBlock Text="Mon prochain quart:"/>

                        <Border Background="#FFD3D3D3" CornerRadius="5" Padding="5" Margin="0,5,0,0">
                            <TextBlock Text="Mar 24 mars, 9h-17h Entrepot"/>
                        </Border>

                        <TextBlock Text="Mes quarts complétés:"/>

                        <Border Background="#FFD3D3D3" CornerRadius="5" Padding="5" Margin="0,5,0,0">
                            <StackPanel>
                                <TextBlock Text="Mar 24 mars, 9h-17h Entrepot"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" CornerRadius="15" Background="White" Padding="15" Margin="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Mes quarts de travail" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold"/>

                        <TextBlock Text="Filtré:"/>
                        <ComboBox IsEnabled="False" Margin="0,0,0,5"/>

                        <TextBlock Text="Trier:"/>
                        <ComboBox IsEnabled="False" Margin="0,0,0,10"/>

                        <StackPanel>
                            <Border Background="#FFD3D3D3" CornerRadius="5" Padding="5" Margin="0,0,0,5">
                                <TextBlock Text="Mar 24 mars, 9h-17 Entrepot"/>
                            </Border>
                            <Border Background="#FFD3D3D3" CornerRadius="5" Padding="5" Margin="0,0,0,5">
                                <TextBlock Text="Mar 31 mars, 8h-18 Vente"/>
                            </Border>
                            <Border Background="#FFD3D3D3" CornerRadius="5" Padding="5" Margin="0,0,0,5">
                                <TextBlock Text="Ven 27 mars, 13h-19 Caisse"/>
                            </Border>
                            <Border Background="#FFD3D3D3" CornerRadius="5" Padding="5" Margin="0,0,0,5">
                                <TextBlock Text="Mer 1 avril, 8h-20 Entrepot"/>
                            </Border>
                            <Border Background="#FFD3D3D3" CornerRadius="5" Padding="5">
                                <TextBlock Text="Mer 30 mars, 14h-20 Section informatique"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </Grid>
</UserControl>