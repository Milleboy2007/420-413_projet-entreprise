<Window x:Class="ScheduleFlow.PageProfil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScheduleFlow"
        mc:Ignorable="d"
        Title="PageProfil" Height="450" Width="800"
        Background="#093C71">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#1C5084" Height="60">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="ScheduleFlow" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>

            <Border Width="40" 
                    Height="40" 
                    CornerRadius="20"
                    Grid.Column="1"
                    Margin="0,0,20,0"
                    VerticalAlignment="Center">
                <Border.Background>
                    <ImageBrush ImageSource="pfp.png"/>
                </Border.Background>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    Background="#1C5084" 
                    Height="35">

            <TextBlock Text="Accueil" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
            <TextBlock Text="Compte" Foreground="White" FontWeight="Bold" Padding="15,8" Background="#1561AF"/>
            <TextBlock Text="Feuilles de disponibilité" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
            <TextBlock Text="Quart de Travail" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
            <TextBlock Text="Demande de Congé" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
            <TextBlock Text="Notifications" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Informations personnelles" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,0,0,15"/>
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Prénom Nom" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="Jane Doe" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Genre" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="Féminin" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Date d'anniversaire" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="15 mars 1995" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Numéro de téléphone personnel" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="(514) 555-1234" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Adresse" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="123 Rue Example, Montréal, QC" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Courriel personnel" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="exemple@gmail.com" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="Informations professionnelles" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,0,0,15"/>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Numéro de téléphone professionnel" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="(514) 555-5678" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Courriel d'entreprise" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="exemple@entreprise.com" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Employeur" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="ABC Corporation" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Poste" 
                               Foreground="LightGray" 
                               FontSize="12"/>
                    <TextBlock Text="Développeur Full Stack" 
                               Foreground="White" 
                               FontSize="15" 
                               FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>


</Window>
