<Page x:Class="ScheduleFlow.pages.Conge"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ScheduleFlow.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="#c2c2c2"
      Title="Conge">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="ScheduleFlow" FontSize="24" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center" Margin="20,0,0,0"/>

                <Border Width="40" Height="40" CornerRadius="20" Grid.Column="1" Margin="0,0,20,0" VerticalAlignment="Center">
                    <Border.Background>
                        <ImageBrush ImageSource="pfp.png"/>
                    </Border.Background>
                </Border>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Background="#1565C0" Height="35">
                <TextBlock Text="Accueil" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
                <TextBlock Text="Compte" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
                <TextBlock Text="Feuilles de disponibilité" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
                <TextBlock Text="Quart de Travail" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
                <TextBlock Text="Annonces" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
                <TextBlock Text="Congé" Foreground="White" FontWeight="SemiBold" Padding="15,8" Background="#0D47A1"/>
                <TextBlock Text="Notifications" Foreground="White" FontWeight="SemiBold" Padding="15,8"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="10">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Filtres:" VerticalAlignment="Center"/>
                    <DatePicker Margin="10,0" Width="180"/>
                    <ComboBox Width="150" Margin="10,0">
                        <ComboBoxItem Content="Employé"/>
                    </ComboBox>
                    <ComboBox Width="150">
                        <ComboBoxItem Content="Type Absence"/>
                    </ComboBox>
                </StackPanel>
                <DataGrid
                          Height="337">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Employé" Width="*"/>
                        <DataGridTextColumn Header="Poste" Width="*"/>
                        <DataGridTextColumn Header="Date Début" Width="*"/>
                        <DataGridTextColumn Header="Date Fin" Width="*"/>
                        <DataGridTextColumn Header="Nbre Jours" Width="*"/>
                        <DataGridTextColumn Header="Type Abs." Width="*"/>
                        <DataGridTextColumn Header="Motif/Notes" Width="2*"/>
                        <DataGridTextColumn Header="Status" Width="*"/>

                        <DataGridTemplateColumn Header="Actions" Width="2*">
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="White"
                    Margin="10"
                    Padding="10"
                    BorderBrush="#CCC"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="Détails de l'Absence"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Date Début"/>
                    <DatePicker Margin="0,5"/>

                    <TextBlock Text="Date Fin"/>
                    <DatePicker Margin="0,5"/>

                    <TextBlock Text="Employé"/>
                    <ComboBox Margin="0,5"/>

                    <TextBlock Text="Type Abs."/>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox Width="100" Margin="0,5">
                            <ComboBoxItem Content="Congé"/>
                        </ComboBox>
                        <ComboBox Width="70" Margin="5,5">
                            <ComboBoxItem Content="Maladie"/>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Text="Motif/Notes"/>
                    <TextBox Height="60" Margin="0,5"/>

                    <TextBlock Text="Status"/>
                    <ComboBox Margin="0,5">
                        <ComboBoxItem Content="En attente"/>
                        <ComboBoxItem Content="Approuvé"/>
                        <ComboBoxItem Content="Refusé"/>
                    </ComboBox>

                    <Button Content="Mettre à jour"
                            Background="#28A745"
                            Foreground="White"
                            Margin="0,10,0,5"/>

                    <Button Content="Refuser"
                            Background="#DC3545"
                            Foreground="White"
                            Margin="0,5"/>

                    <Button Content="Approuver"
                            Background="#28A745"
                            Foreground="White"
                            Margin="0,5"/>

                    <Button Content="Annuler"
                            Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>