<Page x:Class="ScheduleFlow.Pages.Page_Quart_Gerant"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ScheduleFlow.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page_Quart_Gerant"
      Background="#424242">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#0A3663" CornerRadius="10" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#38658E" CornerRadius="10,10,0,0" Height="35" Padding="10,0,10,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="Journée" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                            <TextBlock Grid.Column="2" Text="Heure Début" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                            <TextBlock Grid.Column="3" Text="Heure Fin" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                            <TextBlock Grid.Column="4" Text="Poste" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                            <TextBlock Grid.Column="5" Text="Employée" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                            <TextBlock Grid.Column="6" Text="Status" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1">

                        <Border Background="#3F6B95" BorderBrush="#0A2A4A" BorderThickness="0,0,0,1" Height="30" Padding="10,0,10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="▷" Foreground="Black" Margin="0,0,5,0" FontWeight="Bold"/>
                                <TextBlock Text="Lundi" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#3F6B95" BorderBrush="#0A2A4A" BorderThickness="0,0,0,1" Height="30" Padding="10,0,10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="▷" Foreground="Black" Margin="0,0,5,0" FontWeight="Bold"/>
                                <TextBlock Text="Mardi" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#3F6B95" BorderBrush="#0A2A4A" BorderThickness="0,0,0,1" Height="30" Padding="10,0,10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="▷" Foreground="Black" Margin="0,0,5,0" FontWeight="Bold"/>
                                <TextBlock Text="Mercredi" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#3F6B95" BorderBrush="#0A2A4A" BorderThickness="0,0,0,1" Height="30" Padding="10,0,10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="▷" Foreground="Black" Margin="0,0,5,0" FontWeight="Bold"/>
                                <TextBlock Text="Jeudi" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#3F6B95" BorderBrush="#0A2A4A" BorderThickness="0,0,0,1" Height="30" Padding="10,0,10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="▷" Foreground="Black" Margin="0,0,5,0" FontWeight="Bold"/>
                                <TextBlock Text="Vendredi" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#3F6B95" BorderBrush="#0A2A4A" BorderThickness="0,0,0,1" Height="30" Padding="10,0,10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="▷" Foreground="Black" Margin="0,0,5,0" FontWeight="Bold"/>
                                <TextBlock Text="Samedi" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#3F6B95" BorderBrush="#0A2A4A" BorderThickness="0,0,0,1" Height="30" Padding="10,0,10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="▷" Foreground="Black" Margin="0,0,5,0" FontWeight="Bold"/>
                                <TextBlock Text="Dimanche" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#0A3663" CornerRadius="10" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Détails du Quart" FontSize="20" Margin="0,0,0,15" Foreground="White" />

                    <StackPanel Grid.Row="1">

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Date:" Foreground="White" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="White" CornerRadius="8" Height="22" Padding="5,0,5,0">
                                <DockPanel>
                                    <TextBlock Text="📅" DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="10" Foreground="DimGray"/>
                                    <TextBox Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"/>
                                </DockPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Heure:" Foreground="White" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="White" CornerRadius="8" Height="22">
                                <TextBox Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0,0,0"/>
                            </Border>
                            <Border Grid.Column="3" Background="White" CornerRadius="8" Height="22">
                                <TextBox Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0,0,0"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Poste:" Foreground="White" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="White" CornerRadius="8" Height="22">
                                <TextBox Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0,0,0"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Assignation:" Foreground="White" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="White" CornerRadius="8" Height="22">
                                <TextBox Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="5,0,0,0"/>
                            </Border>
                        </Grid>

                        <StackPanel Margin="0,5,0,0">
                            <TextBlock Text="Description:" Foreground="White" Margin="0,0,0,5"/>
                            <Border Background="White" CornerRadius="10" Height="150" Padding="5">
                                <TextBox Background="Transparent" BorderThickness="0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
