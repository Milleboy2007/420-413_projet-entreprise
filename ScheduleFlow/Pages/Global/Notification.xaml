    <UserControl x:Class="ScheduleFlow.Pages.Global.Notification"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                 xmlns:local="clr-namespace:ScheduleFlow.Pages.Global"
                 mc:Ignorable="d" 
                d:DesignHeight="450" d:DesignWidth="800"
                Background="#FFF0F0F0">
        <Grid Margin="10">
            <StackPanel>
                <TextBlock Text="Mes notifications"
                           FontSize="24"
                            FontWeight="Bold"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Background="#0F4A86" CornerRadius="20" Height="500">
                        <Border Background="#2F6690"
                                CornerRadius="20"
                                Margin="10,10,10,0"
                                Height="80" 
                                VerticalAlignment="Top"
                                >
                        <StackPanel>
                            <Grid Margin="10, 5, 10, 5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Voici une notification"
                                           FontSize="18"
                                           VerticalAlignment="Center"
                                           Grid.Column="0"/>

                                <Button Content="Delete"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Padding="5"
                                        Background="#8B0000"
                                        Foreground="White"/>
                            </Grid>

                            <TextBlock Text="Voici les détails de la notification"
                                       Margin="10, 0, 10, -2"
                                       FontSize="16"/>

                            <TextBlock Text="2026-01-29"
                                       VerticalAlignment="Bottom"
                                       HorizontalAlignment="Right"
                                       Foreground="White"
                                       Margin="10, 5, 10, 0"/>
                        </StackPanel>
                    </Border>
                    </Border>
                </ScrollViewer>
            </StackPanel>

        </Grid>
    </UserControl>
