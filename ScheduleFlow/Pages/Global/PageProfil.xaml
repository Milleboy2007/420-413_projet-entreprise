<UserControl x:Class="ScheduleFlow.Pages.Global.PageProfil"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ScheduleFlow.Pages.Global"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#093C71">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20,20,20,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock Text="Informations personnelles" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       Margin="0,0,0,10"/>
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Prénom Nom" 
                           Foreground="LightGray" 
                           FontSize="12"/>
                    <TextBlock Text="{Binding NomComplet}" 
                           Foreground="White" 
                           FontSize="15" 
                           FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Genre" 
                           Foreground="LightGray" 
                           FontSize="12"/>
                    <TextBlock Text="{Binding Genre}" 
                           Foreground="White" 
                           FontSize="15" 
                           FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Date de Naissance" 
                           Foreground="LightGray" 
                           FontSize="12"/>
                    <TextBlock Text="{Binding DateNaissance}" 
                           Foreground="White" 
                           FontSize="15" 
                           FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Numéro de téléphone personnel" 
                           Foreground="LightGray" 
                           FontSize="12"/>
                    <TextBlock Text="{Binding TelephonePersonnel}" 
                           Foreground="White" 
                           FontSize="15" 
                           FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Adresse" 
                           Foreground="LightGray" 
                           FontSize="12"/>
                    <TextBlock Text="{Binding Adresse}" 
                           Foreground="White" 
                           FontSize="15" 
                           FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Courriel personnel" 
                           Foreground="LightGray" 
                           FontSize="12"/>
                    <TextBlock Text="{Binding Courriel}" 
                           Foreground="White" 
                           FontSize="15" 
                           FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Margin="0,0,20,0" Grid.Column="1">
                <TextBlock Text="Informations professionnelles" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       Margin="0,0,0,15"/>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Numéro de téléphone professionnel" 
                           Foreground="LightGray" 
                           FontSize="12"/>
                    <TextBlock Text="{Binding TelephoneProfessionnel}" 
                           Foreground="White" 
                           FontSize="15" 
                           FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Courriel d'entreprise" 
                           Foreground="LightGray" 
                           FontSize="12"/>
                    <TextBlock Text="{Binding CourrielEntreprise}" 
                           Foreground="White" 
                           FontSize="15" 
                           FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Employeur" 
                           Foreground="LightGray" 
                           FontSize="12"/>
                    <TextBlock Text="{Binding Role}" 
                           Foreground="White" 
                           FontSize="15" 
                           FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Poste" 
                           Foreground="LightGray" 
                           FontSize="12"/>
                    <TextBlock Text="{Binding Ville}" 
                           Foreground="White" 
                           FontSize="15" 
                           FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Modifier mon profil" 
                FontSize="18" 
                FontWeight="Bold" 
                Foreground="White" 
                Margin="0,0,0,15"
                HorizontalAlignment="Center"/>

                <StackPanel Margin="10,0,10,5">
                    <TextBlock Text="Sélectionner l'élement à modifier" 
                    Foreground="LightGray" 
                    FontSize="14" 
                    Width="206"
                    HorizontalAlignment="Center"
                    />
                </StackPanel>

                <ComboBox Margin="0,5,0,20" 
                    Background="#1E1E1E" 
                    Foreground="Black" 
                    FontSize="14" 
                    FontWeight="SemiBold" Width="188" Height="30">
                    <ComboBoxItem Content="Prénom"/>
                    <ComboBoxItem Content="Nom"/>
                    <ComboBoxItem Content="Genre"/>
                    <ComboBoxItem Content="Date d'anniversaire"/>
                    <ComboBoxItem Content="Numéro de téléphone personnel"/>
                    <ComboBoxItem Content="Adresse"/>
                    <ComboBoxItem Content="Courriel personnel"/>
                    <ComboBoxItem Content="Numéro de téléphone professionnel"/>
                    <ComboBoxItem Content="Courriel d'entreprise"/>
                    <ComboBoxItem Content="Employeur"/>
                    <ComboBoxItem Content="Poste"/>
                </ComboBox>

                <StackPanel Margin="20,5,20,10">
                    <TextBlock Text="Nouvelle valeur"
                           Margin="0, 20,0,5"
                           Foreground="LightGray" 
                           FontSize="14"
                           HorizontalAlignment="Center"/>

                    <TextBox Margin="0,5,0,0" 
                        Background="lightgray" 
                        Foreground="Black" 
                        FontSize="14" 
                        FontWeight="SemiBold"
                        Height="25"
                        MinWidth="200"
                        HorizontalAlignment="Center"/>
                </StackPanel>

                <Button Content="Enregistrer les modifications" 
                    Height="40"
                    Margin="0, 40, 0,0"
                    Background="#424242"
                    Foreground="White"
                    VerticalAlignment="Bottom"
                    FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>