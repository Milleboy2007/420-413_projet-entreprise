<UserControl x:Class="ScheduleFlow.Pages.Global.PageProfil"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ScheduleFlow.ViewModels.Global"
             Background="#093C71">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="30">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Colonne 1 : Informations personnelles -->
            <Border Grid.Column="0" Margin="10" Padding="15" CornerRadius="10" Background="#0F4A86">
                <StackPanel>
                    <TextBlock Text="Informations personnelles"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Nom complet" Foreground="LightGray"/>
                    <TextBlock Text="{Binding NomComplet}" Foreground="White" Margin="0,0,0,10"/>

                    <TextBlock Text="Genre" Foreground="LightGray"/>
                    <TextBlock Text="{Binding Genre}" Foreground="White" Margin="0,0,0,10"/>

                    <TextBlock Text="Date de naissance" Foreground="LightGray"/>
                    <TextBlock Text="{Binding DateNaissance}" Foreground="White" Margin="0,0,0,10"/>

                    <TextBlock Text="Téléphone personnel" Foreground="LightGray"/>
                    <TextBlock Text="{Binding TelephonePersonnel}" Foreground="White" Margin="0,0,0,10"/>

                    <TextBlock Text="Adresse" Foreground="LightGray"/>
                    <TextBlock Text="{Binding Adresse}" Foreground="White" Margin="0,0,0,10"/>

                    <TextBlock Text="Courriel" Foreground="LightGray"/>
                    <TextBlock Text="{Binding Courriel}" Foreground="White" Margin="0,0,0,10"/>

                    <TextBlock Text="Code Postal" Foreground="LightGray"/>
                    <TextBlock Text="{Binding CodePostal}" Foreground="White" Margin="0,0,0,10"/>

                    <TextBlock Text="Province / Région" Foreground="LightGray"/>
                    <TextBlock Text="{Binding RegionProvince}" Foreground="White" Margin="0,0,0,10"/>

                    <TextBlock Text="Pays" Foreground="LightGray"/>
                    <TextBlock Text="{Binding Pays}" Foreground="White" Margin="0,0,0,10"/>
                </StackPanel>
            </Border>

            <!-- Colonne 2 : Informations professionnelles -->
            <Border Grid.Column="1" Margin="10,10,10,228" Padding="15" CornerRadius="10" Background="#0F4A86">
                <StackPanel>
                    <TextBlock Text="Informations professionnelles"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Téléphone professionnel" Foreground="LightGray"/>
                    <TextBlock Text="{Binding TelephoneProfessionnel}" Foreground="White" Margin="0,0,0,10"/>

                    <TextBlock Text="Courriel entreprise" Foreground="LightGray"/>
                    <TextBlock Text="{Binding CourrielEntreprise}" Foreground="White" Margin="0,0,0,10"/>

                    <TextBlock Text="Rôle" Foreground="LightGray"/>
                    <TextBlock Text="{Binding Role}" Foreground="White" Margin="0,0,0,10"/>

                    <TextBlock Text="Ville" Foreground="LightGray"/>
                    <TextBlock Text="{Binding Ville}" Foreground="White"/>
                </StackPanel>
            </Border>

            <Border Margin="10,232,10,10" Padding="15" CornerRadius="10" Background="#0F4A86" Grid.Column="1">
                <StackPanel>
                    <TextBlock Text="Contact d'urgence" TextAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>

                    <TextBlock Text="Nom" Foreground="LightGray"/>
                    <TextBlock Text="{Binding NomContactUrgence}" Foreground="White" Margin="0,0,0,5"/>

                    <TextBlock Text="Relation" Foreground="LightGray"/>
                    <TextBlock Text="{Binding LienParente}" Foreground="White" Margin="0,0,0,5"/>

                    <TextBlock Text="Téléphone" Foreground="LightGray"/>
                    <TextBlock Text="{Binding TelephoneContactUrgence}" Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Colonne 3 : Modifier mon profil -->
            <Border Grid.Column="2" Margin="10" Padding="25" CornerRadius="15" Background="#123E6B">
                <StackPanel>
                    <TextBlock Text="Modifier mon profil"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,30"
                               HorizontalAlignment="Center"
                               Opacity="0.9"/>

                    <TextBlock Text="Élément à modifier"
                               Foreground="LightGray"
                               Margin="5,0,0,5"
                               FontSize="13"/>

                    <ComboBox ItemsSource="{Binding ChampsProfil}"
                              SelectedItem="{Binding ElementSelectionne}"
                              Height="35"
                              Margin="0,0,0,25"
                              Width="751"
/>

                    <TextBlock Text="Nouvelle information"
                               Foreground="LightGray"
                               Margin="5,0,0,5"
                               FontSize="13"/>

                    <Grid Margin="0,0,0,30">
                        <TextBox Text="{Binding NouvelleValeur, UpdateSourceTrigger=PropertyChanged}"
                             Height="35"
                             VerticalContentAlignment="Center"
                             Padding="5,0">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRoleSelectionActive}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <Border Background="#44FFA500" CornerRadius="5" Padding="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRoleSelectionActive}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Modification impossible, seul un administrateur peut changer votre rôle."
                                           Foreground="Orange"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           TextAlignment="Center"/>
                        </Border>
                    </Grid>
                    <StackPanel>
                        
                    <!-- Bouton de sauvegarde -->
                    <Button Content="Enregistrer les modifications"
                                    Height="45"
                                    Background="#1F1F1F"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Margin="15"
                                    Cursor="Hand"
                                    Command="{Binding ModifierCompteCommand}" Width="200">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementSelectionne}" Value="{x:Null}">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Supprimer le compte"
                            Height="40"
                            Background="#8B0000"
                            Foreground="White"
                            BorderBrush="White"
                            BorderThickness="1"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Command="{Binding SupprimerCompteCommand}" Width="200" RenderTransformOrigin="0.497,1.968"/>

                    <!-- Bouton de suppression -->
                </StackPanel>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>