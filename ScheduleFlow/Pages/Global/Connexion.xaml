<UserControl x:Class="ScheduleFlow.Pages.Global.Connexion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ScheduleFlow.Pages.Global"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border Background="White" CornerRadius="15" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center">

            <StackPanel Width="300">
                <TextBlock Text="ScheduleFlow" FontSize="32" FontWeight="Bold" Foreground="#1C5084" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Mode de développement" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button x:Name="BtnEmploye" Content="Connexion Employé" 
                        Click="BtnEmploye_Click"
                        Height="50" Background="#1561AF" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,15">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="BtnGerant" Content="Connexion Gérant" 
                        Click="BtnGerant_Click"
                        Height="50" Background="#424242" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,15">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
                
                <Button x:Name="BtnEmployeur" Content="Connexion Employeur" 
                    Click="BtnEmployeur_Click"
                    Height="50" Background="red" Foreground="White" FontSize="16" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
